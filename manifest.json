{
  "manifest_version": 3,
  "name": "PrairiePlus",
  "version": "1.0",
  "description": "A PrairieLearn extension that adds several useful features.",
  "action": {
    "default_popup": "popup.html"
  },
  "permissions": [
    "activeTab",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "*://*.prairielearn.com/*",
    "*://*.prairielearn.org/*",
    "*://us.prairielearn.com/*",
    "http://localhost/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.prairielearn.com/*", "*://*.prairielearn.org/*", "*://us.prairielearn.com/*", "http://localhost/*"],
      "css": ["lib/katex/katex.min.css", "dark-mode.css"],
      "js": ["lib/katex/katex.min.js", "content.js", "tracker.js"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["lib/katex/fonts/*"],
      "matches": ["*://*.prairielearn.com/*", "*://*.prairielearn.org/*", "*://us.prairielearn.com/*", "http://localhost/*"]
    }
  ],
  "icons": {
    "128": "icons/icon128.png"
  }
}
