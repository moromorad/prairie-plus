{
  "manifest_version": 3,
  "name": "PrarieLearn Extension ",
  "version": "1.0",
  "description": "PrarieLearn Extension",
  "action": {
    "default_popup": "popup.html"
  },
  "permissions": [
    "activeTab",
    "storage"
  ],
  "content_scripts": [
    {
      "matches": ["*://*.prairielearn.com/*", "*://*.prairielearn.org/*", "*://us.prairielearn.com/*"],
      "css": ["dark-mode.css"],
      "js": ["content.js"]
    }
  ]
}
