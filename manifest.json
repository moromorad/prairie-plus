{
  "manifest_version": 3,
  "name": "PrairieLearn Extension ",
  "version": "1.0",
  "description": "PrairieLearn Extension",
  "action": {
    "default_popup": "popup.html"
  },
  "permissions": [
    "activeTab",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "*://*.prairielearn.com/*",
    "*://*.prairielearn.org/*",
    "*://us.prairielearn.com/*",
    "http://localhost/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.prairielearn.com/*", "*://*.prairielearn.org/*", "*://us.prairielearn.com/*", "http://localhost/*"],
      "css": ["dark-mode.css"],
      "js": ["content.js", "tracker.js"]
    }
  ]
}
